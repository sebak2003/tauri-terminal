{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Tauri Terminal",
  "version": "1.0.0",
  "identifier": "com.tauri-terminal.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Tauri Terminal",
        "width": 960,
        "height": 760,
        "minWidth": 600,
        "minHeight": 500,
        "decorations": false,
        "center": true
      }
    ]
  }
}
